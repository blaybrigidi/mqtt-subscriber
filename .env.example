# Copy this file to .env and fill in your values before running the service.
# Never commit the real .env file — it contains secrets.

# Secret key shared between this service and the prediction model
RUST_TO_MODEL_KEY=your_secret_key_here

# Messaging server (HiveMQ) connection details
MQTT_HOST=your_hivemq_host_here
MQTT_PORT=8883
MQTT_CLIENT_ID=your_client_id_here
MQTT_USERNAME=your_mqtt_username_here
MQTT_PASSWORD=your_mqtt_password_here

# The patient ID — used to subscribe to the right channel and store readings correctly
USER_ID=your_patient_user_id_here

# Where the prediction model is running
MODEL_URL=http://localhost:8000/predict

# Firebase Realtime Database URL
DATABASE_URL=https://your-project.firebasedatabase.app
